# Copy this file to .env and fill in your values

# LLM Provider API Keys (leave empty to use mock mode)
GEMINI_API_KEY=
GROQ_API_KEY=

# TokenTamer Auth — used as X-API-Key header in all requests
TOKENTAMER_API_KEY=tokentamer-secret-key-change-me

# Database
DATABASE_URL=sqlite:///./tokentamer.db

# Server
HOST=0.0.0.0
PORT=8000
DEBUG=true

# Policy Defaults
MAX_TOKENS_PER_REQUEST=4096
DAILY_BUDGET_CAP_USD=5.0
RATE_LIMIT_RPM=50
ROUTING_STRATEGY=hybrid

# Cache
CACHE_TTL_SECONDS=3600
CACHE_MAX_SIZE=500